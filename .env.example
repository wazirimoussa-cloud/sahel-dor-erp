# Copiez ce fichier vers .env.local et renseignez les valeurs de votre projet Supabase
# (Dashboard Supabase > Project Settings > API)

VITE_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key

# Utilisé UNIQUEMENT par les scripts d'intégration et les Edge Functions,
# jamais exposé au frontend. Ne jamais committer une vraie valeur.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Optionnel : affiche une bannière en haut de l'app (ex. déploiement de formation/démo,
# pour éviter toute confusion avec la production). Laisser vide en production.
VITE_APP_LABEL=
